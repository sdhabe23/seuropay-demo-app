# SeuroPay Backend — Environment Variables
# Copy this file to .env and fill in your Tink sandbox credentials.
#
# ⚠️  NEVER commit the real .env file — it is gitignored.
# For GitHub Actions / CI, add these as repository secrets:
#   GitHub repo → Settings → Secrets and variables → Actions → New repository secret
#
#   Required secrets:
#     TINK_CLIENT_ID      — from console.tink.com
#     TINK_CLIENT_SECRET  — from console.tink.com
#     SESSION_SECRET      — any long random string (openssl rand -hex 32)
#     VITE_API_BASE       — your deployed backend URL, e.g. https://api.seuropay.com
#                           (leave blank/empty to use same-origin, for local dev)

# ─── Tink Sandbox Credentials ────────────────────────────────────────────────
TINK_CLIENT_ID=your_tink_client_id
TINK_CLIENT_SECRET=your_tink_client_secret

# Tink API base (sandbox)
TINK_API_BASE=https://api.tink.com

# ─── OAuth Redirect URIs ─────────────────────────────────────────────────────
# Must match EXACTLY what you register in Tink Console → Your App → Redirect URIs.
#
# Local dev:  http://localhost:5173
# Production: https://demo.seuropay.com  (or your deployed frontend URL)
#
# Tink redirects the user's browser here after bank login.
# The frontend (main.tsx) then forwards the ?code= to /api/tink/callback.
TINK_REDIRECT_URI=http://localhost:5173
TINK_PIS_REDIRECT_URI=http://localhost:5173

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=4000
# Generate a strong secret: openssl rand -hex 32
SESSION_SECRET=change-me-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:5173
